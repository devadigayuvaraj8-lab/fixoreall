{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "androidStatusBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Fixo to access your location to auto-fill address and find nearby technicians."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.yuvarajdevadig.frontend"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Fixo to access your location to auto-fill address and find nearby technicians."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "googleAuth": {
        "androidClientId": "894507788819-bjpadgetj84lf2p8jl4ut9bsqgau1h3d.apps.googleusercontent.com",
        "webClientId": "894507788819-r3a6cpmtn2cr2na1fcb50spr75dsjfka.apps.googleusercontent.com"
      },
      "eas": {
        "projectId": "6f346464-a68e-44a4-a1dd-95ffa5ff67e6"
      }
    }
  }
}